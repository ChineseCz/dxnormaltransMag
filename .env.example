# ============================================================
#  存储配置示例
#  复制此文件为 .env 并根据需要修改
# ============================================================

# ── 存储后端选择 ──
# 可选值: local | minio | oss | cos
STORAGE_BACKEND=local

# ============================================================
#  本地文件系统配置（STORAGE_BACKEND=local）
# ============================================================
# 无需额外配置，默认使用项目根目录的 datasets/ 文件夹

# ============================================================
#  MinIO 配置（STORAGE_BACKEND=minio）
# ============================================================
MINIO_ENDPOINT=localhost:9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=dx-platform
MINIO_SECURE=false

# ============================================================
#  阿里云 OSS 配置（STORAGE_BACKEND=oss）
# ============================================================
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=LTAI5t...
# OSS_ACCESS_KEY_SECRET=xxx...
# OSS_BUCKET=dx-platform-prod

# ============================================================
#  腾讯云 COS 配置（STORAGE_BACKEND=cos）
# ============================================================
# COS_REGION=ap-shanghai
# COS_SECRET_ID=AKIDxxxxx
# COS_SECRET_KEY=xxxxx
# COS_BUCKET=dx-platform-1234567890

# ============================================================
#  数据库配置（已有）
# ============================================================
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=dx_user
PG_PASSWORD=dx123456
PG_DB=dx_platform_db

# ============================================================
#  Redis 配置（已有）
# ============================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# ============================================================
#  JWT 配置（已有）
# ============================================================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

