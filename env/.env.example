# ============================================================
#  dx-platform 环境变量模板
#  使用方式：复制为 .env，填入真实值后启动
#    cp .env.example .env
# ============================================================

# ── 数据库模式 ────────────────────────────────────────────────────────────────
# 可选值: pg | sqlite
# 留空或 pg 时自动尝试 Docker PostgreSQL，连不上则降级 SQLite
DB_MODE=pg

# ── PostgreSQL 连接 ────────────────────────────────────────────────────────────
# 对应 docker-compose 中 postgres 服务（localhost:5432）
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=dx_user
PG_PASSWORD=dx123456
PG_DB=dx_platform_db

# ── JWT 安全密钥 ──────────────────────────────────────────────
# 生产环境请换成随机长字符串，例如：
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_in_production_please

# ── Qwen / 阿里云百炼 API Key ─────────────────────────────────
# 在 https://dashscope.aliyuncs.com 控制台获取
# 不填时 /api/ai/chat 使用 Mock 回答（本地开发可不填）
DASHSCOPE_API_KEY=sk-363e72f368a24c8ea99d804c1a20bbc8

# ── Redis（Celery 消息队列）──────────────────────────────────
# 默认指向 Docker Redis，本地开发一般不需要改
REDIS_URL=redis://localhost:6379/0

